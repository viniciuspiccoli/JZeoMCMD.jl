# ────────────────────────────────────────────────────────────
# SPECIAL BONDS & NEIGHBORS
# ────────────────────────────────────────────────────────────
special_bonds   lj 0.0 0.0 1.0 coul 0.0 0.0 1.0 angle yes dihedral yes
neighbor        2.0 bin
neigh_modify    every 5 delay 0 check yes one 5000 page 150000
