# ============================================================
# hillsauer_alumsil_loaded.ff
# Hill-Sauer (framework) + TraPPE-UA (ethanol) for loaded H-ZSM-5
#
# Usage:  include hillsauer_alumsil_loaded.ff
#
# Atom types:
#   1=Al  2=Hb  3=O(Oss)  4=Oas  5=Ob  6=Si  7=Si_a  8=Si_b
#   9=CH3_eth  10=CH2_eth  11=O_eth  12=H_eth
#
# Framework:   Hill-Sauer 1994/1995, mHSFF (Boulfelfel 2016)
# Ethanol:     TraPPE-UA (Siepmann et al.)
# Cross:       Bai et al. 2013 LJ + Lorentz-Berthelot mixing
# Charges:     H-S bond increments (fw) + TraPPE partial charges (eth)
#
# Bond/angle/dihedral types 1-6/1-10/1-10 = framework (same as _empty.ff)
# Additional ethanol bonded types:
#   bond    7 = CH3-CH2     8 = CH2-O_eth    9 = O_eth-H_eth
#   angle  11 = CH3-CH2-O   12 = CH2-O-H
#   dihedral 11 = CH3-CH2-O-H  (OPLS)
# ============================================================

# ────────────────────────────────────────────────────────────
# MASSES
# ────────────────────────────────────────────────────────────
mass   1  26.981538  # Al
mass   2   1.00794   # Hb
mass   3  15.9994    # O (Oss)
mass   4  15.9994    # Oas
mass   5  15.9994    # Ob
mass   6  28.0855    # Si
mass   7  28.0855    # Si_a
mass   8  28.0855    # Si_b
mass   9  15.035     # CH3 (TraPPE-UA)
mass  10  14.027     # CH2 (TraPPE-UA)
mass  11  15.9994    # O_eth
mass  12   1.008     # H_eth

# ────────────────────────────────────────────────────────────
# CHARGES
# ────────────────────────────────────────────────────────────
# Framework (H-S bond increments)
set type   1 charge  0.5366    # Al
set type   2 charge  0.0839    # Hb
set type   3 charge -0.2618    # Oss
set type   4 charge -0.2959    # Oas
set type   5 charge -0.2515    # Ob
set type   6 charge  0.5236    # Si
set type   7 charge  0.5192    # Si_a
set type   8 charge  0.5319    # Si_b
# Ethanol (TraPPE-UA)
set type   9 charge  0.000     # CH3
set type  10 charge  0.265     # CH2
set type  11 charge -0.700     # O_eth
set type  12 charge  0.435     # H_eth

# ────────────────────────────────────────────────────────────
# PAIR STYLE — table (fw-fw) + LJ (fw-eth, eth-eth) + Coulomb
# ────────────────────────────────────────────────────────────
pair_style      hybrid/overlay table spline 2000 lj/cut 12.0 coul/long 12.0
pair_modify     tail no shift no
kspace_style    ewald 1.0E-06

pair_coeff      * * coul/long

# ── fw-fw: tabulated A/r^9 (same 36 pairs as _empty.ff) ──
pair_coeff  1  1 table hillsauer_alumino.table Al_Al
pair_coeff  1  2 table hillsauer_alumino.table Al_Hb
pair_coeff  1  3 table hillsauer_alumino.table Al_O
pair_coeff  1  4 table hillsauer_alumino.table Al_Oas
pair_coeff  1  5 table hillsauer_alumino.table Al_Ob
pair_coeff  1  6 table hillsauer_alumino.table Al_Si
pair_coeff  1  7 table hillsauer_alumino.table Al_Si_a
pair_coeff  1  8 table hillsauer_alumino.table Al_Si_b
pair_coeff  2  2 table hillsauer_alumino.table Hb_Hb
pair_coeff  2  3 table hillsauer_alumino.table Hb_O
pair_coeff  2  4 table hillsauer_alumino.table Hb_Oas
pair_coeff  2  5 table hillsauer_alumino.table Hb_Ob
pair_coeff  2  6 table hillsauer_alumino.table Hb_Si
pair_coeff  2  7 table hillsauer_alumino.table Hb_Si_a
pair_coeff  2  8 table hillsauer_alumino.table Hb_Si_b
pair_coeff  3  3 table hillsauer_alumino.table O_O
pair_coeff  3  4 table hillsauer_alumino.table O_Oas
pair_coeff  3  5 table hillsauer_alumino.table O_Ob
pair_coeff  3  6 table hillsauer_alumino.table O_Si
pair_coeff  3  7 table hillsauer_alumino.table O_Si_a
pair_coeff  3  8 table hillsauer_alumino.table O_Si_b
pair_coeff  4  4 table hillsauer_alumino.table Oas_Oas
pair_coeff  4  5 table hillsauer_alumino.table Oas_Ob
pair_coeff  4  6 table hillsauer_alumino.table Oas_Si
pair_coeff  4  7 table hillsauer_alumino.table Oas_Si_a
pair_coeff  4  8 table hillsauer_alumino.table Oas_Si_b
pair_coeff  5  5 table hillsauer_alumino.table Ob_Ob
pair_coeff  5  6 table hillsauer_alumino.table Ob_Si
pair_coeff  5  7 table hillsauer_alumino.table Ob_Si_a
pair_coeff  5  8 table hillsauer_alumino.table Ob_Si_b
pair_coeff  6  6 table hillsauer_alumino.table Si_Si
pair_coeff  6  7 table hillsauer_alumino.table Si_Si_a
pair_coeff  6  8 table hillsauer_alumino.table Si_Si_b
pair_coeff  7  7 table hillsauer_alumino.table Si_a_Si_a
pair_coeff  7  8 table hillsauer_alumino.table Si_a_Si_b
pair_coeff  8  8 table hillsauer_alumino.table Si_b_Si_b

# ── eth-eth: TraPPE-UA LJ ──
pair_coeff   9   9 lj/cut  0.19476  3.750    # CH3 (ε=98K×kB)
pair_coeff  10  10 lj/cut  0.09128  3.950    # CH2 (ε=46K×kB)
pair_coeff  11  11 lj/cut  0.18509  3.020    # O_eth (ε=93.0K×kB)  (TraPPE)
pair_coeff  12  12 lj/cut  0.00000  0.000    # H_eth (no LJ)

# ── fw-eth cross: Bai 2013 LJ (Lorentz-Berthelot) ──
# Bai framework LJ:  O_fw: ε=0.1855 σ=2.806  Si: ε=0.0413 σ=1.564
# All O types (3,4,5) use same Bai O params; Si types (6,7,8) use same Si params
# Al treated as Si (approximate); Hb treated as zero LJ

# O_fw(3,4,5) × CH3(9):  ε=√(0.1855×0.19476)=0.19008  σ=(2.806+3.750)/2=3.278
pair_coeff   3   9 lj/cut  0.19008  3.278
pair_coeff   4   9 lj/cut  0.19008  3.278
pair_coeff   5   9 lj/cut  0.19008  3.278
# O_fw(3,4,5) × CH2(10): ε=√(0.1855×0.09128)=0.13009  σ=(2.806+3.950)/2=3.378
pair_coeff   3  10 lj/cut  0.13009  3.378
pair_coeff   4  10 lj/cut  0.13009  3.378
pair_coeff   5  10 lj/cut  0.13009  3.378
# O_fw(3,4,5) × O_eth(11): ε=√(0.1855×0.18509)=0.18530  σ=(2.806+3.020)/2=2.913
pair_coeff   3  11 lj/cut  0.18530  2.913
pair_coeff   4  11 lj/cut  0.18530  2.913
pair_coeff   5  11 lj/cut  0.18530  2.913
# O_fw(3,4,5) × H_eth(12): zero
pair_coeff   3  12 lj/cut  0.00000  1.000
pair_coeff   4  12 lj/cut  0.00000  1.000
pair_coeff   5  12 lj/cut  0.00000  1.000

# Si(6,7,8) × CH3(9): ε=√(0.0413×0.19476)=0.08970  σ=(1.564+3.750)/2=2.657
pair_coeff   6   9 lj/cut  0.08970  2.657
pair_coeff   7   9 lj/cut  0.08970  2.657
pair_coeff   8   9 lj/cut  0.08970  2.657
# Si(6,7,8) × CH2(10): ε=√(0.0413×0.09128)=0.06140  σ=(1.564+3.950)/2=2.757
pair_coeff   6  10 lj/cut  0.06140  2.757
pair_coeff   7  10 lj/cut  0.06140  2.757
pair_coeff   8  10 lj/cut  0.06140  2.757
# Si(6,7,8) × O_eth(11): ε=√(0.0413×0.18509)=0.08742  σ=(1.564+3.020)/2=2.292
pair_coeff   6  11 lj/cut  0.08742  2.292
pair_coeff   7  11 lj/cut  0.08742  2.292
pair_coeff   8  11 lj/cut  0.08742  2.292
# Si(6,7,8) × H_eth(12): zero
pair_coeff   6  12 lj/cut  0.00000  1.000
pair_coeff   7  12 lj/cut  0.00000  1.000
pair_coeff   8  12 lj/cut  0.00000  1.000

# Al(1) × eth: treat as Si (Bai)
pair_coeff   1   9 lj/cut  0.08970  2.657
pair_coeff   1  10 lj/cut  0.06140  2.757
pair_coeff   1  11 lj/cut  0.08742  2.292
pair_coeff   1  12 lj/cut  0.00000  1.000
# Hb(2) × eth: small H, approximate as zero
pair_coeff   2   9 lj/cut  0.00000  1.000
pair_coeff   2  10 lj/cut  0.00000  1.000
pair_coeff   2  11 lj/cut  0.00000  1.000
pair_coeff   2  12 lj/cut  0.00000  1.000

# eth-eth cross (LB mixing auto-generated, but explicit here)
pair_coeff   9  10 lj/cut  0.13334  3.850    # CH3-CH2
pair_coeff   9  11 lj/cut  0.18990  3.385    # CH3-O_eth
pair_coeff   9  12 lj/cut  0.00000  1.000    # CH3-H_eth
pair_coeff  10  11 lj/cut  0.12994  3.485    # CH2-O_eth
pair_coeff  10  12 lj/cut  0.00000  1.000    # CH2-H_eth
pair_coeff  11  12 lj/cut  0.00000  1.000    # O_eth-H_eth

